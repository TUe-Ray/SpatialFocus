{
  "experiment_family": "eomt_selective_3d_round2",
  "description": "Round-2 ablation: word-class matching filter (on/off) x empty fallback (all_3d/zero_3d), all with soft gate, 100% data full run.",
  "shared": {
    "mm_eomt_selective_3d_enable": true,
    "mm_eomt_selective_3d_gate_type": "soft",
    "mm_eomt_selective_3d_selector_mode": "confidence",
    "mm_eomt_selective_3d_score_threshold": 0.8,
    "mm_eomt_selective_3d_topk": -1,
    "mm_eomt_selective_3d_class_type": "things",
    "mm_eomt_selective_3d_merge_mode": "soft_max_union",
    "eomt_smoke_test_enable": false,
    "eomt_smoke_test_max_samples": 4
  },
  "modes": {
    "soft_word_match_all3d": {
      "mm_eomt_selective_3d_word_match_enable": true,
      "mm_eomt_selective_3d_empty_fallback": "all_3d"
    },
    "soft_word_match_zero3d": {
      "mm_eomt_selective_3d_word_match_enable": true,
      "mm_eomt_selective_3d_empty_fallback": "zero_3d"
    },
    "soft_no_word_match_all3d": {
      "mm_eomt_selective_3d_word_match_enable": false,
      "mm_eomt_selective_3d_empty_fallback": "all_3d"
    },
    "soft_no_word_match_zero3d": {
      "mm_eomt_selective_3d_word_match_enable": false,
      "mm_eomt_selective_3d_empty_fallback": "zero_3d"
    }
  }
}
