{
  "experiment_family": "eomt_selective_3d_round1",
  "description": "Round-1 ablation for svf_patch_only: full 3D patch branch vs selective 3D patch gating using max foreground class probability.",
  "shared": {
    "mm_eomt_selector_mode": "confidence",
    "mm_eomt_selector_score_threshold": 0.8,
    "mm_eomt_selector_topk": -1,
    "mm_eomt_selector_class_type": "things",
    "mm_eomt_selective_3d_merge_mode": "soft_max_union",
    "mm_eomt_selective_3d_floor": 0.1,
    "mm_eomt_selective_3d_empty_fallback": "all_3d",
    "eomt_smoke_test_enable": true,
    "eomt_smoke_test_max_samples": 4
  },
  "modes": {
    "baseline": {
      "mm_eomt_selective_3d_enable": false
    },
    "selective_soft": {
      "mm_eomt_selective_3d_enable": true,
      "mm_eomt_selective_3d_gate_type": "soft",
      "mm_eomt_selective_3d_empty_fallback": "all_3d"
    },
    "selective_soft_with_floor": {
      "mm_eomt_selective_3d_enable": true,
      "mm_eomt_selective_3d_gate_type": "soft_with_floor",
      "mm_eomt_selective_3d_floor": 0.1,
      "mm_eomt_selective_3d_empty_fallback": "all_3d"
    },
    "selective_soft_with_floor_zero_fallback": {
      "mm_eomt_selective_3d_enable": true,
      "mm_eomt_selective_3d_gate_type": "soft_with_floor",
      "mm_eomt_selective_3d_floor": 0.1,
      "mm_eomt_selective_3d_empty_fallback": "zero_3d"
    }
  }
}
